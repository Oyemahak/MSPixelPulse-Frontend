{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/login",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/register",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/debug",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/admin/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/client/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/dev/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    }
  ],
  "routes": [
    {
      "src": "/admin(?:/.*)?",
      "dest": "/portal-shell",
      "headers": { "X-Robots-Tag": "noindex, nofollow, noarchive" }
    },
    {
      "src": "/client(?:/.*)?",
      "dest": "/portal-shell",
      "headers": { "X-Robots-Tag": "noindex, nofollow, noarchive" }
    },
    {
      "src": "/dev(?:/.*)?",
      "dest": "/portal-shell",
      "headers": { "X-Robots-Tag": "noindex, nofollow, noarchive" }
    },
    { "handle": "filesystem" },
    { "src": "/.*", "status": 404, "dest": "/404.html" }
  ]
}
